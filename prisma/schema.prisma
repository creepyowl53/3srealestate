// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  AGENT
  ADMIN
  SUPER_ADMIN
}

enum LeadStatus {
  NEW
  CONTACTED
  INTERESTED
  SITE_VISIT
  NEGOTIATION
  CLOSED
  LOST
}

enum LeadScore {
  HOT
  WARM
  COLD
}

enum PropertyType {
  RESIDENTIAL
  COMMERCIAL
  PLOT
  FLAT
  RENTAL
  AGRICULTURAL
  VILLA
  LUXURY
}

enum PropertyStatus {
  AVAILABLE
  SOLD
  UNDER_NEGOTIATION
  COMING_SOON
}

enum PropertyPurpose {
  SALE
  RENT
  INVESTMENT
}

enum FurnishingStatus {
  UNFURNISHED
  SEMI_FURNISHED
  FULLY_FURNISHED
}

enum PossessionStatus {
  READY_TO_MOVE
  UNDER_CONSTRUCTION
  NEW_LAUNCH
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  phone         String?
  password      String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  savedProperties  SavedProperty[]
  inquiries        Inquiry[]
  appointments     Appointment[]
  recentlyViewed   RecentlyViewed[]
  comparisons      PropertyComparison[]
  assignedLeads    Lead[]              @relation("AgentLeads")
  activityLogs     ActivityLog[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Lead {
  id                String     @id @default(cuid())
  fullName          String
  phone             String
  email             String?
  budget            String?
  preferredLocation String?
  propertyType      String?
  purpose           String?
  timeline          String?
  status            LeadStatus @default(NEW)
  score             LeadScore  @default(COLD)
  source            String?    @default("website")
  notes             String?    @db.Text
  assignedToId      String?
  assignedTo        User?      @relation("AgentLeads", fields: [assignedToId], references: [id])
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  followUps  FollowUp[]
  reminders  Reminder[]

  @@map("leads")
}

model FollowUp {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  note      String   @db.Text
  type      String   @default("CALL")
  createdAt DateTime @default(now())

  @@map("follow_ups")
}

model Reminder {
  id          String   @id @default(cuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  title       String
  description String?
  dueDate     DateTime
  isDone      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@map("reminders")
}

model Property {
  id               String           @id @default(cuid())
  title            String
  slug             String           @unique
  description      String           @db.Text
  type             PropertyType
  purpose          PropertyPurpose
  status           PropertyStatus   @default(AVAILABLE)
  price            Float
  priceLabel       String?
  area             Float
  areaUnit         String           @default("sqft")
  bedrooms         Int?
  bathrooms        Int?
  parking          Int?
  furnishing       FurnishingStatus?
  possession       PossessionStatus?
  floor            Int?
  totalFloors      Int?
  facing           String?
  age              Int?
  isFeatured       Boolean          @default(false)
  isLuxury         Boolean          @default(false)
  investmentReturn Float?
  city             String
  locality         String
  address          String
  mapEmbedUrl      String?
  latitude         Float?
  longitude        Float?
  builderName      String?
  builderLogo      String?
  reraNumber       String?
  coverImage       String
  brochureUrl      String?
  videoUrl         String?
  virtualTourUrl   String?
  metaTitle        String?
  metaDescription  String?
  metaKeywords     String?
  viewCount        Int              @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  images         PropertyImage[]
  amenities      PropertyAmenity[]
  nearbyFacility NearbyFacility[]
  inquiries      Inquiry[]
  savedBy        SavedProperty[]
  recentlyViewed RecentlyViewed[]
  comparisons    PropertyComparison[]
  appointments   Appointment[]

  @@map("properties")
}

model PropertyImage {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  url        String
  alt        String?
  isPrimary  Boolean  @default(false)
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  @@map("property_images")
}

model PropertyAmenity {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  name       String
  icon       String?

  @@map("property_amenities")
}

model NearbyFacility {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  name       String
  type       String
  distance   String

  @@map("nearby_facilities")
}

model Inquiry {
  id         String   @id @default(cuid())
  propertyId String?
  property   Property? @relation(fields: [propertyId], references: [id])
  userId     String?
  user       User?     @relation(fields: [userId], references: [id])
  name       String
  phone      String
  email      String?
  message    String?  @db.Text
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@map("inquiries")
}

model Appointment {
  id         String            @id @default(cuid())
  propertyId String?
  property   Property?         @relation(fields: [propertyId], references: [id])
  userId     String?
  user       User?             @relation(fields: [userId], references: [id])
  name       String
  phone      String
  email      String?
  date       DateTime
  message    String?           @db.Text
  status     AppointmentStatus @default(PENDING)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@map("appointments")
}

model SavedProperty {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, propertyId])
  @@map("saved_properties")
}

model RecentlyViewed {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  viewedAt   DateTime @default(now())

  @@unique([userId, propertyId])
  @@map("recently_viewed")
}

model PropertyComparison {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, propertyId])
  @@map("property_comparisons")
}

model BlogCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())

  blogs Blog[]

  @@map("blog_categories")
}

model Blog {
  id              String       @id @default(cuid())
  title           String
  slug            String       @unique
  excerpt         String       @db.Text
  content         String       @db.Text
  coverImage      String?
  categoryId      String?
  category        BlogCategory? @relation(fields: [categoryId], references: [id])
  tags            String[]
  isPublished     Boolean      @default(false)
  isFeatured      Boolean      @default(false)
  metaTitle       String?
  metaDescription String?
  viewCount       Int          @default(0)
  publishedAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@map("blogs")
}

model Testimonial {
  id         String   @id @default(cuid())
  name       String
  role       String?
  company    String?
  avatar     String?
  content    String   @db.Text
  rating     Int      @default(5)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@map("testimonials")
}

model ContactForm {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String?
  subject   String?
  message   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("contact_forms")
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  entity    String?
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@map("activity_logs")
}

model SiteSettings {
  id          String  @id @default(cuid())
  key         String  @unique
  value       String  @db.Text
  description String?

  @@map("site_settings")
}
