# Database
DATABASE_URL="postgresql://username:password@localhost:5432/3s_real_estate?schema=public"

# Auth.js / NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-minimum-32-chars"

# Google OAuth (optional)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Email (Resend/Nodemailer)
EMAIL_SERVER_HOST="smtp.gmail.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER="your-email@gmail.com"
EMAIL_SERVER_PASSWORD="your-app-password"
EMAIL_FROM="3S Real Estate <noreply@3srealestate.com>"

# WhatsApp Business API (optional)
WHATSAPP_API_URL="https://api.whatsapp.com"
WHATSAPP_PHONE_NUMBER="+919876543210"

# App Config
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="3S Real Estate"
NEXT_PUBLIC_WHATSAPP_NUMBER="+919876543210"

# Rate Limiting
RATE_LIMIT_MAX="10"
RATE_LIMIT_WINDOW="60000"
